.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
  background-color: var(--td-bg-color-page);
}

.loading-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--td-bg-color-page);
}

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 48rpx 32rpx 40rpx;
  border-radius: 12rpx;
  background-color: var(--td-bg-color-container);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--td-brand-color);
  background-color: var(--td-bg-color-secondarycontainer);
}

.profile-name {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.profile-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.actions {
  margin-top: 48rpx;
}
