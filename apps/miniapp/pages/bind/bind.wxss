.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background-color: var(--td-bg-color-page);
}

.loading-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--td-bg-color-page);
}

.loading-text {
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
}

.hero {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--td-text-color-secondary);
}

.form {
  margin-bottom: 48rpx;
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.tips {
  padding: 24rpx;
  border-radius: 12rpx;
  background-color: var(--td-bg-color-container);
}

.tips-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--td-text-color-primary);
}

.tips-item {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--td-text-color-secondary);
}
