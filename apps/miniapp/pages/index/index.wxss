.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background-color: var(--td-bg-color-page);
}

.hero {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
}

.footer {
  margin-top: 32rpx;
  padding: 0 8rpx;
}

.hint {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--td-text-color-placeholder);
}
