{
  "name": "@easyshift/api",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"no lint configured\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@easyshift/shared-types": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@hono/zod-validator": "^0.7.0",
    "dotenv": "^16.5.0",
    "bcryptjs": "^3.0.2",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.32",
    "drizzle-kit": "^0.31.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
