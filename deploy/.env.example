# 复制到仓库根目录为 .env（服务器上：/opt/easyshift/.env）
# 暂无域名时：用 ECS 公网 IP 访问，例如 http://47.96.x.x

# ── MySQL（Compose 内网，勿对外开放 3306）──
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=easyshift
MYSQL_USER=easyshift
MYSQL_PASSWORD=change-me-db

# ── API ──
NODE_ENV=production
PORT=3000
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
WEB_SESSION_TTL_DAYS=7
MINIAPP_TOKEN_TTL_DAYS=30
WX_APPID=
WX_SECRET=
# production 环境必须为 false；暂无域名阶段只测 Web/API，不测小程序真机登录
WX_MOCK=false
WX_MOCK_OPENID=mock_openid_staging
# 暂无域名：填 http://你的ECS公网IP（不要末尾斜杠）
CORS_ORIGIN=http://YOUR_ECS_PUBLIC_IP
# HTTP 无域名阶段用 false；上 HTTPS 后改 true
COOKIE_SECURE=false
SEED_ADMIN_PASSWORD=Admin@123456

# ── Web 构建（同域反代，一般不用改）──
VITE_API_BASE_URL=/api/v1

# ── 对外端口 ──
HTTP_PORT=80
